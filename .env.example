# Node API
PORT=4000
CORS_ORIGIN=http://localhost:3000
SQLITE_PATH=./data/ezrnd-flow.sqlite

# Original Next.js frontend expects this name.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Temporary dev login used by the original UI's /api/auth/dev-login route.
LOGIN_USER_ID=dev@example.com
LOGIN_USER_PASSWORD=dev-password

# LangChain/OpenAI architecture agent (optional; fallback mode works without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
